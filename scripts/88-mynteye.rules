# MYNT EYE S1030 / S2100 / S210A udev rules
# Allows non-root access to the camera over USB.
# The tested S1030/D1000 path enumerates with 1e4e:0120 and the IMU with
# 0483:5720. Older units may use the legacy Slightech/Cypress IDs.

SUBSYSTEMS=="usb", ATTRS{idVendor}=="04b4", MODE="0666", GROUP="video"
SUBSYSTEMS=="usb", ATTRS{idVendor}=="2207", MODE="0666", GROUP="video"
SUBSYSTEMS=="usb", ATTRS{idVendor}=="1e4e", MODE="0666", GROUP="video"
SUBSYSTEMS=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5720", MODE="0666", GROUP="video"

# Avoid autosuspend on the camera, IMU and integrated Genesys hubs. Some units
# disconnect a few seconds after enumeration if the host suspends them early.
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="1e4e", ATTR{idProduct}=="0120", \
    TEST=="power/control", ATTR{power/control}="on"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="5720", \
    TEST=="power/control", ATTR{power/control}="on"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="05e3", ATTR{idProduct}=="0610", \
    TEST=="power/control", ATTR{power/control}="on"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="05e3", ATTR{idProduct}=="0626", \
    TEST=="power/control", ATTR{power/control}="on"

# Friendly /dev symlink for MYNT EYE video nodes.
KERNEL=="video[0-9]*", SUBSYSTEMS=="usb", ATTRS{idVendor}=="04b4", \
    SYMLINK+="mynteye"
KERNEL=="video[0-9]*", SUBSYSTEMS=="usb", ATTRS{idVendor}=="1e4e", \
    SYMLINK+="mynteye"